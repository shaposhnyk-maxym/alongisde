<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Required at runtime on API 33+ to actually display push notifications. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Photo access for the diary's EXIF import - split by API level per Android's own
         permission migration (READ_MEDIA_IMAGES replaces READ_EXTERNAL_STORAGE on 33+). -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Required on API 29+ so AndroidExifPhotoReader can read unredacted GPS EXIF tags via
         MediaStore.setRequireOriginal() - without it, every photo's location silently reads as
         null (scoped storage privacy redaction). Runtime request not wired up yet - see
         AndroidExifPhotoReader's kdoc and roadmap.md M10. -->
    <uses-permission android:name="android.permission.ACCESS_MEDIA_LOCATION" />

    <application
        android:name=".AlongsideApplication"
        android:label="Alongside"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name="com.alongside.app.push.AlongsideFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>
